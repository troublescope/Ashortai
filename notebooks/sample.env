# ═══════════════════════════════════════════════════════════════
# OpenSource Clipping — Sample .env Config
# ═══════════════════════════════════════════════════════════════
# Copy isi file ini ke cell config notebook OSC_PasteConfig.ipynb
# Atau simpan sebagai .env di root project untuk CLI usage.
# Hanya key yang perlu diubah; yang lain pakai default T4-optimized.


VIDEO_URL=https://youtu.be/aniUcHajo4I?si=_hh20FZsx_Hk0Cde
SOURCE_PLATFORM=youtube
AI_PROVIDER=ollama
AI_MODEL=gemini-3-flash-preview:cloud
OLLAMA_URL=https://ollama.com
OLLAMA_API_KEY=
GOOGLE_API_KEY=
NVIDIA_API_KEY=                              # hanya jika pakai nvidia

# ── ✂️ CLIPPING SETTINGS ──
MAX_CLIPS=5
ASPECT_RATIO=9:16
RENDER_HEIGHT=1080
SOURCE_HEIGHT=max
FONT_STYLE=HORMOZI
FACE_DETECTOR=mediapipe
YOLO_SIZE=8m

# ── 💬 SUBTITLE & TRANSCRIPTION ──
ENABLE_SUBTITLES=True
USE_KARAOKE_EFFECT=True
WORDS_PER_SUBTITLE=5
USE_YT_TRANSCRIPT_API=True
USE_DLP_SUBS=True
WHISPER_MODEL=large-v3
WHISPER_DEVICE=auto
WHISPER_COMPUTE_TYPE=float16

# ── 📦 OUTPUT & QUALITY ──
VIDEO_PRESET=fast
VIDEO_SCALE_ALGO=bicubic
VIDEO_CQ=23
VIDEO_CRF=20
ENABLE_COLAB_CLEANUP=True

# ── 🔧 ADVANCED / OPTIONAL ──
DISABLE_BGM=True
DISABLE_BROLL=True
DISABLE_HOOK_GLITCH=False
ENABLE_HOOK_V2=False
HOOK_DURATION=3
ENABLE_SPLIT_SCREEN=False
ENABLE_CAMERA_SWITCH=False
HF_TOKEN=                                  # wajib jika split-screen/camera-switch
